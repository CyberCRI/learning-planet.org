# Matomo analytics (self-hosted, CONSENT-GATED — standing decision of
# 15 July 2026; see src/components/Matomo.astro before touching anything).
# Both values are public (they ship in the rendered HTML); they are env-driven
# only for flexibility. Production values are set in .github/workflows/astro.yml.
#
# The snippet renders only in production builds (`astro build`) AND only when
# the site ID is set: leave PUBLIC_MATOMO_SITE_ID unset locally so local
# builds stay untracked. `astro dev` never tracks.
#
# A future preview/staging deployment must use a separate throwaway Matomo
# site ID here, never "1", to avoid polluting production statistics.
PUBLIC_MATOMO_URL=https://analytics.learning-planet.org/
PUBLIC_MATOMO_SITE_ID=1
