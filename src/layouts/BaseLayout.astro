---
import '~/styles/fonts.css';
import '~/styles/global.css';
import Header from '~/components/Header.astro';
import Footer from '~/components/Footer.astro';
import CookieConsent from '~/components/CookieConsent.astro';
import Matomo from '~/components/Matomo.astro';
import { buildSeo, type SeoProps } from '~/lib/seo';
import { useTranslations, type Locale } from '~/i18n/utils';
import { SITE } from '~/site';
import { withBase } from '~/lib/paths';

type Props = Omit<SeoProps, 'locale'> & {
  locale?: Locale;
};

const locale: Locale = (Astro.props.locale ?? (Astro.currentLocale as Locale) ?? 'en');
const { title, description, path, image, noindex } = Astro.props;
const t = useTranslations(locale);

const seo = buildSeo({ title, description, path, image, noindex, locale }, Astro.site);
const fullTitle = title === SITE.name ? `${SITE.name} — ${SITE.descriptor}` : `${title} — ${SITE.name}`;
// Default social card: generated by scripts/generate-og.mjs (--ship c).
// ?v= busts social crawlers' image caches (keyed by exact URL) — bump it
// whenever the card artwork changes.
const ogImage = new URL(image ?? withBase('og-card.jpg?v=2'), Astro.site).href;
const ogImageAlt = `${SITE.name} — 25–29 January 2027, by Learning Planet Institute & UNESCO. Illustration created with AI.`;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={seo.canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    {seo.alternates.map((a) => <link rel="alternate" hreflang={a.hreflang} href={a.href} />)}

    <link rel="icon" type="image/png" href={withBase('favicon.png')} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={`${SITE.name} — ${SITE.descriptor}`} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={seo.canonical} />
    <meta property="og:image" content={ogImage} />
    {!image && <meta property="og:image:type" content="image/jpeg" />}
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta property="og:locale" content={seo.ogLocale} />
    <meta property="og:locale:alternate" content={seo.ogLocaleAlternate} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={ogImageAlt} />

    <meta name="theme-color" content="#0b2b33" />

    <Matomo />
  </head>
  <body>
    <a class="skip-link" href="#main">{t('common.skipToContent')}</a>
    <Header locale={locale} />
    <main id="main">
      <slot />
    </main>
    <Footer locale={locale} />
    <CookieConsent locale={locale} />
  </body>
</html>
