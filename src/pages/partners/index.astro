---
import BaseLayout from '~/layouts/BaseLayout.astro';
import PageHero from '~/components/PageHero.astro';
import PartnersWall from '~/components/PartnersWall.astro';
import EmptyState from '~/components/EmptyState.astro';
import partners from '~/data/partners.json';
import { show } from '~/config';
import { useTranslations } from '~/i18n/utils';

const locale = 'en';
const t = useTranslations(locale);

const hasPartners = show.partners && partners.length > 0;

const intro =
  'We are an open coalition of more than 500 partners worldwide. Our network connects schools, youth-led initiatives, NGOs, research centers, policy think tanks, governments, and international organisations, creating bridges between grassroots communities and global institutions. This breadth and diversity enable us to engage at every level of education and governance – local, national, and international.';
---

<BaseLayout
  title={t('partners.title')}
  description="An open coalition of more than 500 partner organisations worldwide supporting the LearningPlanet Festival."
  path="partners"
  locale={locale}
  noindex={!hasPartners}
>
  {
    hasPartners ? (
      <PartnersWall locale={locale} intro={intro} />
    ) : (
      <>
        <PageHero eyebrow="LearningPlanet Festival 2027" title={t('partners.title')} intro={intro} />
        <EmptyState title={t('partners.title')} message={t('held.partnersEmpty')} locale={locale} />
      </>
    )
  }
</BaseLayout>
