---
import { LEGACY_REDIRECTS } from '~/data/legacyRedirects';
import { withBase } from '~/lib/paths';

export function getStaticPaths() {
  return Object.keys(LEGACY_REDIRECTS).map((legacy) => ({ params: { legacy } }));
}

const { legacy } = Astro.params;
const target = withBase(LEGACY_REDIRECTS[legacy!]);
const canonical = new URL(target, Astro.site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Redirecting…</title>
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <link rel="canonical" href={canonical} />
    <meta name="robots" content="noindex" />
  </head>
  <body>
    <p>This page has moved: <a href={target}>{canonical}</a></p>
  </body>
</html>
