---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Hero from '~/components/Hero.astro';
import MovementSection from '~/components/MovementSection.astro';
import ThemesGrid from '~/components/ThemesGrid.astro';
import CuratedEdition from '~/components/CuratedEdition.astro';
import StatCounters from '~/components/StatCounters.astro';
import PartnerMarquee from '~/components/PartnerMarquee.astro';
import ReplaysTeaser from '~/components/ReplaysTeaser.astro';
import StayInformedCta from '~/components/StayInformedCta.astro';
import { show } from '~/config';
import { SITE } from '~/site';

const locale = 'en';
---

<BaseLayout
  title={SITE.name}
  description="The LearningPlanet Festival returns in January 2027, around the International Day of Education. A global movement for reimagining education — learning to take care of oneself, others and the planet."
  path=""
  locale={locale}
>
  <Hero locale={locale} />
  {show.themes && <ThemesGrid locale={locale} />}
  <CuratedEdition locale={locale} />
  <MovementSection locale={locale} />
  <StatCounters locale={locale} />
  {show.partners && <PartnerMarquee locale={locale} />}
  <ReplaysTeaser locale={locale} />
  <StayInformedCta locale={locale} />
</BaseLayout>
