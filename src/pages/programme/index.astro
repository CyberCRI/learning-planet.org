---
import BaseLayout from '~/layouts/BaseLayout.astro';
import PageHero from '~/components/PageHero.astro';
import ThemesGrid from '~/components/ThemesGrid.astro';
import EmptyState from '~/components/EmptyState.astro';
import { safeCollection } from '~/lib/collections';
import { show } from '~/config';
import { useTranslations } from '~/i18n/utils';

const locale = 'en';
const t = useTranslations(locale);

// Render CONFIRMED entries only.
const events = (await safeCollection('events', (e) => e.data.status === 'confirmed')).sort(
  (a, b) => (a.data.start?.getTime() ?? 0) - (b.data.start?.getTime() ?? 0)
);
const hasProgramme = show.programme && events.length > 0;
---

<BaseLayout
  title={t('held.programmeTitle')}
  description="The LearningPlanet Festival 2027 programme. Full schedule announced soon."
  path="programme"
  locale={locale}
  noindex={!hasProgramme}
>
  <PageHero eyebrow="LearningPlanet Festival 2027" title={t('held.programmeTitle')} />

  {
    hasProgramme ? (
      <section class="section container">
        <ul class="programme-list">
          {events.map((event) => (
            <li>
              <a href={`/event/${event.id}`}>
                <h3>{event.data.title}</h3>
                <p>{event.data.summary}</p>
              </a>
            </li>
          ))}
        </ul>
      </section>
    ) : (
      <EmptyState title={t('held.programmeTitle')} message={t('held.programmeEmpty')} locale={locale} />
    )
  }

  {show.themes && <ThemesGrid locale={locale} />}
</BaseLayout>
