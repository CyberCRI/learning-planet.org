---
/**
 * DESIGN LAB (temporary) — team review: two designs for the homepage
 * "Key themes" section, shown live one under the other. Noindexed and out
 * of the sitemap; not linked from the site. Delete together with
 * src/components/lab/ once the team has decided.
 */
import BaseLayout from '~/layouts/BaseLayout.astro';
import ThemesGrid from '~/components/ThemesGrid.astro';
import ThemesWall from '~/components/lab/ThemesWall.astro';
import { withBase } from '~/lib/paths';

const locale = 'en';
---

<BaseLayout
  title="Key themes — two options (team review)"
  description="Team review page comparing two designs for the homepage key-themes section."
  path="design-lab/key-themes"
  locale={locale}
  noindex={true}
>
  <section class="section review-intro">
    <div class="container">
      <p class="eyebrow">Team review</p>
      <h1 class="h-bold review-title">Key themes — two options</h1>
      <p class="review-text">
        Same six themes, same copy — two presentations. Option A is what the
        <a href={withBase('')}>homepage</a> shows today; option B is the "lineup wall" from the
        design explorations. This page is unlisted and hidden from search engines.
      </p>
    </div>
  </section>

  <div class="option-band" id="option-a">
    <div class="container">
      <span class="option-tag">Option A</span>
      <span class="option-name">Current homepage — colour-card grid</span>
    </div>
  </div>
  <ThemesGrid locale={locale} />

  <div class="option-band" id="option-b">
    <div class="container">
      <span class="option-tag">Option B</span>
      <span class="option-name">Lineup wall — rows expand to reveal each question (tap the +)</span>
    </div>
  </div>
  <ThemesWall locale={locale} />

  <section class="section review-outro">
    <div class="container">
      <a class="btn btn-primary" href={withBase('design-lab/home-with-wall/')}>See option B on the full homepage</a>
      <a class="btn btn-outline" href={withBase('')}>Current homepage</a>
    </div>
  </section>
</BaseLayout>

<style>
  .review-intro {
    padding-block: var(--sp-5) var(--sp-4);
  }
  .review-title {
    font-size: var(--fs-800);
    margin-bottom: var(--sp-2);
  }
  .review-text {
    max-width: 60ch;
    font-size: var(--fs-500);
    color: var(--ink-soft);
    margin: 0;
  }
  .review-text a {
    color: var(--c-deep-teal);
  }

  .option-band {
    background: var(--ink);
    color: var(--paper);
    padding-block: 0.7rem;
  }
  .option-band .container {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 0.4rem 1rem;
  }
  .option-tag {
    font-family: var(--font-display);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: var(--fs-300);
    background: var(--c-yellow);
    color: var(--ink);
    border-radius: 999px;
    padding: 0.1rem 0.7rem;
  }
  .option-name {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--fs-400);
  }

  .review-outro .container {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
  }
</style>
