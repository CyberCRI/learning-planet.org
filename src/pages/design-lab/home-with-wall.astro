---
/**
 * DESIGN LAB (temporary) — the current production homepage with ONE swap:
 * the key-themes lineup wall (option B) in place of the colour-card grid.
 * For the team review at /design-lab/key-themes. Noindexed, unlisted.
 */
import BaseLayout from '~/layouts/BaseLayout.astro';
import LabBanner from '~/components/lab/LabBanner.astro';
import Hero from '~/components/Hero.astro';
import ThemesWall from '~/components/lab/ThemesWall.astro';
import CuratedEdition from '~/components/CuratedEdition.astro';
import MovementSection from '~/components/MovementSection.astro';
import StatCounters from '~/components/StatCounters.astro';
import PartnerMarquee from '~/components/PartnerMarquee.astro';
import ReplaysTeaser from '~/components/ReplaysTeaser.astro';
import StayInformedCta from '~/components/StayInformedCta.astro';
import { show } from '~/config';

const locale = 'en';
---

<BaseLayout
  title="Homepage with lineup wall — team review"
  description="Team review page: the current homepage with the key-themes lineup wall (option B)."
  path="design-lab/home-with-wall"
  locale={locale}
  noindex={true}
>
  <LabBanner label="Homepage with option B — lineup wall" />
  <Hero locale={locale} />
  {show.themes && <ThemesWall locale={locale} />}
  <CuratedEdition locale={locale} />
  <MovementSection locale={locale} />
  <StatCounters locale={locale} />
  {show.partners && <PartnerMarquee locale={locale} />}
  <ReplaysTeaser locale={locale} />
  <StayInformedCta locale={locale} />
</BaseLayout>
