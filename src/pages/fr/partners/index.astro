---
import BaseLayout from '~/layouts/BaseLayout.astro';
import PageHero from '~/components/PageHero.astro';
import PartnersWall from '~/components/PartnersWall.astro';
import EmptyState from '~/components/EmptyState.astro';
import partners from '~/data/partners.json';
import { show } from '~/config';
import { useTranslations } from '~/i18n/utils';

const locale = 'fr';
const t = useTranslations(locale);

const hasPartners = show.partners && partners.length > 0;

const intro =
  "Nous sommes une coalition ouverte regroupant plus de 500 partenaires à travers le monde. Notre réseau relie des écoles, des initiatives menées par des jeunes, des ONG, des centres de recherche, des groupes de réflexion sur les politiques, des gouvernements et des organisations internationales, créant ainsi des ponts entre les communautés locales et les institutions mondiales. Cette ampleur et cette diversité nous permettent de nous engager à tous les niveaux de l'éducation et de la gouvernance, qu'ils soient locaux, nationaux ou internationaux.";
---

<BaseLayout
  title={t('partners.title')}
  description="Une coalition ouverte de plus de 500 organisations partenaires à travers le monde soutenant le Learning Planet Festival."
  path="partners"
  locale={locale}
  noindex={!hasPartners}
>
  {
    hasPartners ? (
      <PartnersWall locale={locale} intro={intro} />
    ) : (
      <>
        <PageHero eyebrow="Learning Planet Festival 2027" title={t('partners.title')} intro={intro} />
        <EmptyState title={t('partners.title')} message={t('held.partnersEmpty')} locale={locale} />
      </>
    )
  }
</BaseLayout>
