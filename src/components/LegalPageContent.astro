---
import PageHero from './PageHero.astro';
import { useTranslations, type Locale } from '~/i18n/utils';
import type { LegalPage } from '~/data/legal';

interface Props {
  page: LegalPage;
  locale: Locale;
  showManageCookies?: boolean;
}
const { page, locale, showManageCookies = false } = Astro.props;
const t = useTranslations(locale);
---

<PageHero title={page.title} />

<section class="section container">
  <div class="legal-body">
    <p class="legal-updated">{page.updated}</p>

    {
      page.sections.map((section) => (
        <div class="legal-section">
          {section.heading && <h2>{section.heading}</h2>}
          <div set:html={section.html} />
        </div>
      ))
    }

    {
      showManageCookies && (
        <button type="button" class="btn btn-primary" data-open-cookie-banner>
          {t('cookieConsent.manage')}
        </button>
      )
    }
  </div>
</section>

<style>
  .legal-body {
    max-width: 70ch;
  }
  .legal-updated {
    color: var(--ink-faint);
    font-size: var(--fs-300);
    margin-bottom: var(--sp-5);
  }
  .legal-section {
    margin-bottom: var(--sp-4);
  }
  .legal-section h2 {
    font-size: var(--fs-600);
    margin-bottom: var(--sp-2);
  }
  .legal-body :global(p) {
    color: var(--ink-soft);
  }
  .legal-body :global(ul),
  .legal-body :global(ol) {
    color: var(--ink-soft);
    margin: 0 0 1.1rem;
    padding-left: 1.4rem;
  }
  .legal-body :global(ul) {
    list-style: disc;
  }
  .legal-body :global(ol) {
    list-style: decimal;
  }
  .legal-body :global(li) {
    margin-bottom: 0.5rem;
  }
  .legal-body :global(a) {
    color: var(--c-deep-teal);
    text-decoration: underline;
    text-underline-offset: 0.18em;
  }
  .legal-body :global(strong) {
    color: var(--ink);
  }
  .legal-body :global(table.legal-table) {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--fs-300);
    margin: var(--sp-2) 0 var(--sp-4);
    display: block;
    overflow-x: auto;
  }
  .legal-body :global(table.legal-table th),
  .legal-body :global(table.legal-table td) {
    text-align: left;
    padding: 0.6rem 0.8rem;
    border-bottom: 1px solid var(--line);
  }
  .legal-body :global(table.legal-table th) {
    font-weight: 700;
    color: var(--ink);
  }
  .legal-body :global(table.legal-table td) {
    color: var(--ink-soft);
  }
  .legal-body .btn {
    margin-top: var(--sp-3);
  }
</style>
