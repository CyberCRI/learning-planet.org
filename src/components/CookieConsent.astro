---
import { useTranslations, localizedPath, type Locale } from '~/i18n/utils';
interface Props { locale: Locale }
const { locale } = Astro.props;
const t = useTranslations(locale);
---
<div id="cookie-consent" class="cookie-banner" role="dialog" aria-live="polite"
     aria-labelledby="cookie-consent-title" aria-describedby="cookie-consent-body" hidden>
  <div class="container cookie-banner-inner">
    <div class="cookie-banner-copy">
      <p id="cookie-consent-title" class="cookie-banner-title">{t('cookieConsent.title')}</p>
      <p id="cookie-consent-body" class="cookie-banner-body">
        {t('cookieConsent.body')}
        <a href={localizedPath('cookies-policy', locale)}>{t('cookieConsent.learnMore')}</a>
      </p>
    </div>
    <div class="cookie-banner-actions">
      <button type="button" class="btn btn-outline" data-cookie-decline>{t('cookieConsent.decline')}</button>
      <button type="button" class="btn btn-primary" data-cookie-accept>{t('cookieConsent.accept')}</button>
    </div>
  </div>
</div>

<script>
  const STORAGE_KEY = 'lpf_cookie_choice';

  function getPaq() {
    return ((window as any)._paq = (window as any)._paq || []);
  }

  const banner = document.getElementById('cookie-consent');
  const declineBtn = banner?.querySelector<HTMLButtonElement>('[data-cookie-decline]');
  const acceptBtn = banner?.querySelector<HTMLButtonElement>('[data-cookie-accept]');

  function show() {
    banner?.removeAttribute('hidden');
    declineBtn?.focus();
  }

  function hide() {
    banner?.setAttribute('hidden', '');
  }

  acceptBtn?.addEventListener('click', () => {
    try {
      localStorage.setItem(STORAGE_KEY, 'accepted');
    } catch {
      // ignore storage errors (e.g. private browsing)
    }
    getPaq().push(['rememberCookieConsentGiven']);
    hide();
  });

  declineBtn?.addEventListener('click', () => {
    try {
      localStorage.setItem(STORAGE_KEY, 'declined');
    } catch {
      // ignore storage errors (e.g. private browsing)
    }
    getPaq().push(['forgetCookieConsentGiven']);
    hide();
  });

  (window as any).__openCookieBanner = show;
  document.querySelectorAll('[data-open-cookie-banner]').forEach((el) => {
    el.addEventListener('click', show);
  });

  try {
    if (!localStorage.getItem(STORAGE_KEY)) show();
  } catch {
    show();
  }
</script>

<style>
  .cookie-banner {
    position: fixed;
    inset: auto 0 0 0;
    z-index: 100;
    background: var(--ink);
    color: rgba(255, 255, 255, 0.92);
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }
  .cookie-banner[hidden] {
    display: none;
  }
  .cookie-banner-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-3);
    flex-wrap: wrap;
    padding-block: var(--sp-3);
  }
  .cookie-banner-copy {
    flex: 1 1 40ch;
    min-width: 240px;
  }
  .cookie-banner-title {
    font-family: var(--font-display);
    font-weight: 700;
    margin: 0 0 0.3rem;
  }
  .cookie-banner-body {
    font-size: var(--fs-300);
    color: rgba(255, 255, 255, 0.75);
    margin: 0;
  }
  .cookie-banner-body a {
    color: var(--white);
    text-decoration: underline;
    text-underline-offset: 0.18em;
  }
  .cookie-banner-actions {
    display: flex;
    gap: var(--sp-2);
    flex-shrink: 0;
  }
  .cookie-banner-actions .btn-outline {
    background: transparent;
    color: var(--white);
    border-color: rgba(255, 255, 255, 0.4);
  }
  .cookie-banner-actions .btn-outline:hover {
    border-color: var(--white);
  }
  .cookie-banner-actions .btn-primary {
    background: var(--white);
    color: var(--ink);
  }
  .cookie-banner-actions .btn-primary:hover {
    background: rgba(255, 255, 255, 0.85);
  }

  @media (prefers-reduced-motion: reduce) {
    .cookie-banner,
    .cookie-banner .btn {
      transition: none !important;
    }
  }

  @media (max-width: 560px) {
    .cookie-banner-inner {
      flex-direction: column;
      align-items: stretch;
    }
    .cookie-banner-actions {
      justify-content: flex-end;
    }
  }
</style>
