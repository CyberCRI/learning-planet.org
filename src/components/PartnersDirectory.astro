---
import partners from '~/data/partners.json';
import { withBase } from '~/lib/paths';
import { useTranslations, type Locale } from '~/i18n/utils';

interface Props {
  locale: Locale;
  lead?: string;
}
const { locale, lead } = Astro.props;
const t = useTranslations(locale);

/** Normalise a name for search matching: lowercase, strip diacritics, collapse whitespace. */
function normName(value: string): string {
  return value
    .toLowerCase()
    .normalize('NFD')
    .replace(/\p{M}/gu, '')
    .replace(/\s+/g, ' ')
    .trim();
}

// Distinct letter buckets, digits first then A–Z. (Data order can't be used
// directly: quote-prefixed names like “Yes…and” sort before the digits.)
const letters = [...new Set(partners.map((p) => p.letter))].sort((a, b) => {
  const digitA = /^\d$/.test(a);
  const digitB = /^\d$/.test(b);
  if (digitA !== digitB) return digitA ? -1 : 1;
  return a.localeCompare(b);
});
---

<div class="partners-directory">
  {lead && <p class="directory-lead">{lead}</p>}
  <h2 class="h-bold directory-heading">{t('partners.allHeading')}</h2>

  <div class="directory-toolbar" hidden>
    <div class="search-field">
      <label class="visually-hidden" for="partner-search">{t('partners.searchLabel')}</label>
      <input
        id="partner-search"
        type="search"
        placeholder={t('partners.searchPlaceholder')}
        autocomplete="off"
      />
    </div>

    <div class="letter-tabs" role="group" aria-label={t('partners.filterLabel')}>
      <button type="button" data-letter="" aria-pressed="true">{t('partners.all')}</button>
      {letters.map((letter) => (
        <button type="button" data-letter={letter} aria-pressed="false">
          {letter}
        </button>
      ))}
    </div>

    <p
      class="directory-status"
      aria-live="polite"
      data-count-template={t('partners.count', { count: '{count}' })}
      data-no-results={t('partners.noResults')}
    ></p>
  </div>

  <ul class="partner-grid">
    {
      partners.map((p, i) => (
        <li data-letter={p.letter} data-search={normName(p.name)}>
          {p.website ? (
            <a href={p.website} target="_blank" rel="noopener noreferrer">
              <span class="partner-logo">
                <img
                  src={withBase(p.logo)}
                  alt=""
                  width={p.width}
                  height={p.height}
                  loading={i < 12 ? 'eager' : 'lazy'}
                  decoding="async"
                />
              </span>
              <span class="partner-name">{p.name}</span>
            </a>
          ) : (
            <span class="partner-card">
              <span class="partner-logo">
                <img
                  src={withBase(p.logo)}
                  alt=""
                  width={p.width}
                  height={p.height}
                  loading={i < 12 ? 'eager' : 'lazy'}
                  decoding="async"
                />
              </span>
              <span class="partner-name">{p.name}</span>
            </span>
          )}
        </li>
      ))
    }
  </ul>
</div>

<style>
  .directory-lead {
    font-size: var(--fs-500);
    color: var(--ink-soft);
    max-width: var(--maxw-prose);
    margin-bottom: var(--sp-4);
  }
  .directory-heading {
    font-size: var(--fs-700);
    margin-bottom: var(--sp-3);
  }

  /* The scoped display rule would defeat the UA's [hidden] handling —
     keep the toolbar truly hidden until the filter script reveals it. */
  .directory-toolbar[hidden] {
    display: none;
  }
  .directory-toolbar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--sp-2) var(--sp-3);
    margin-bottom: var(--sp-4);
  }
  .search-field {
    flex: 0 0 auto;
  }
  .search-field input {
    font-family: var(--font-body);
    font-size: var(--fs-400);
    color: var(--ink);
    background: var(--white);
    border: 1px solid var(--line-strong);
    border-radius: var(--radius-sm);
    padding: 0.55rem 0.9rem;
    min-width: 220px;
  }
  .search-field input::placeholder {
    color: var(--ink-faint);
  }

  .letter-tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .letter-tabs button {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--fs-300);
    color: var(--ink-soft);
    background: var(--white);
    border: 1.5px solid var(--line-strong);
    border-radius: 999px;
    padding: 0.3rem 0.7rem;
    cursor: pointer;
    transition:
      background-color 0.15s ease,
      border-color 0.15s ease,
      color 0.15s ease;
  }
  .letter-tabs button:hover {
    border-color: var(--c-deep-teal);
  }
  .letter-tabs button[aria-pressed='true'] {
    background: var(--ink);
    border-color: var(--ink);
    color: var(--white);
  }

  .directory-status {
    flex-basis: 100%;
    font-size: var(--fs-300);
    color: var(--ink-soft);
    margin: 0;
  }

  .partner-grid {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    gap: var(--sp-3);
  }
  .partner-grid li {
    display: flex;
  }
  .partner-grid li[hidden] {
    display: none;
  }
  .partner-grid a,
  .partner-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
    width: 100%;
    background: var(--white);
    border: 1px solid var(--line);
    border-radius: var(--radius-sm);
    padding: var(--sp-2);
    text-decoration: none;
    transition:
      border-color 0.15s ease,
      box-shadow 0.15s ease;
  }
  .partner-grid a:hover {
    border-color: var(--line-strong);
    box-shadow: var(--shadow-sm);
  }
  .partner-logo {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 76px;
    width: 100%;
  }
  .partner-logo img {
    max-height: 100%;
    max-width: 100%;
    width: auto;
    object-fit: contain;
  }
  .partner-name {
    font-size: var(--fs-300);
    color: var(--ink-soft);
    text-align: center;
    line-height: 1.3;
  }

  @media (max-width: 560px) {
    .search-field input {
      width: 100%;
      min-width: 0;
    }
  }
</style>

<script>
  const toolbar = document.querySelector<HTMLDivElement>('.directory-toolbar');
  const searchInput = document.querySelector<HTMLInputElement>('#partner-search');
  const tabButtons = document.querySelectorAll<HTMLButtonElement>('.letter-tabs button');
  const status = document.querySelector<HTMLParagraphElement>('.directory-status');
  const items = document.querySelectorAll<HTMLLIElement>('.partner-grid li');

  if (toolbar && searchInput && status) {
    toolbar.hidden = false;

    const countTemplate = status.dataset.countTemplate ?? '';
    const noResultsText = status.dataset.noResults ?? '';

    let activeLetter = '';

    function normalize(value: string): string {
      return value
        .toLowerCase()
        .normalize('NFD')
        .replace(/\p{M}/gu, '')
        .replace(/\s+/g, ' ')
        .trim();
    }

    function applyFilters() {
      const query = normalize(searchInput!.value);
      const isFiltered = activeLetter !== '' || query !== '';
      let visibleCount = 0;

      items.forEach((li) => {
        const letter = li.dataset.letter ?? '';
        const search = li.dataset.search ?? '';
        const matches = (activeLetter === '' || letter === activeLetter) && search.includes(query);
        li.hidden = !matches;
        if (matches) visibleCount += 1;
      });

      if (!isFiltered) {
        status!.textContent = '';
      } else if (visibleCount === 0) {
        status!.textContent = noResultsText;
      } else {
        status!.textContent = countTemplate.replace('{count}', String(visibleCount));
      }
    }

    searchInput.addEventListener('input', applyFilters);

    tabButtons.forEach((button) => {
      button.addEventListener('click', () => {
        activeLetter = button.dataset.letter ?? '';
        tabButtons.forEach((b) => b.setAttribute('aria-pressed', String(b === button)));
        applyFilters();
      });
    });
  }
</script>
