---
import { sharedGoals } from '~/data/whoWeAre';

const themeShade: Record<string, string> = {
  '--c-green': '--c-deep-green',
  '--c-blue': '--c-deep-teal',
  '--c-lilac': '--c-slate',
  '--c-coral': '--c-brown',
};
---

<ul class="goals-grid">
  {
    sharedGoals.map((goal, i) => (
      <li
        class="goal-card"
        style={`--fill: var(${goal.color}); --shade: var(${themeShade[goal.color] ?? '--c-deep-teal'});`}
      >
        <span class="goal-num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
        <h3 class="goal-title">{goal.title}</h3>
        <p class="goal-desc">{goal.description}</p>
      </li>
    ))
  }
</ul>

<style>
  .goals-grid {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 20rem), 1fr));
    gap: clamp(0.9rem, 1.8vw, 1.4rem);
  }
  .goal-card {
    position: relative;
    background: var(--fill);
    color: var(--ink);
    border-radius: var(--radius);
    padding: clamp(1.4rem, 2.4vw, 2rem);
    overflow: hidden;
    box-shadow: var(--shadow);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .goal-card::after {
    content: '';
    position: absolute;
    inset: auto 0 0 0;
    height: 6px;
    background: var(--shade);
    opacity: 0.55;
  }
  .goal-num {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--fs-500);
    letter-spacing: 0.12em;
    opacity: 0.65;
  }
  .goal-title {
    font-family: var(--font-display);
    font-weight: 700;
    text-transform: uppercase;
    line-height: 1.02;
    font-size: clamp(1.3rem, 1rem + 1.2vw, 1.7rem);
    margin: 0;
  }
  .goal-desc {
    margin: 0;
    color: color-mix(in srgb, var(--ink) 86%, transparent);
    font-size: var(--fs-400);
    line-height: 1.5;
  }
</style>
