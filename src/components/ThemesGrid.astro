---
import { themes } from '~/data/themes';
import { useTranslations, type Locale } from '~/i18n/utils';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);

// Dark brand companion per bright, for each card's tactile underside band.
const themeShade: Record<string, string> = {
  '--c-green': '--c-deep-green',
  '--c-blue': '--c-deep-teal',
  '--c-lilac': '--c-slate',
  '--c-coral': '--c-brown',
  '--c-yellow': '--c-olive',
  '--c-deep-green': '--c-deep-teal',
};
// Bright fills take dark ink; the lone deep-green block takes white.
const onDark = new Set(['--c-deep-green']);
---

<section class="section themes" id="themes" aria-labelledby="themes-title">
  <div class="container">
    <header class="themes-head">
      <p class="eyebrow">{t('themes.eyebrow')}</p>
      <h2 id="themes-title" class="h-bold themes-title">{t('themes.heading')}</h2>
    </header>

    <ul class="themes-grid">
      {
        themes.map((th, i) => (
          <li
            class:list={['theme-card', { 'on-dark': onDark.has(th.color) }]}
            style={`--fill: var(${th.color}); --shade: var(${themeShade[th.color] ?? '--c-deep-teal'});`}
          >
            <span class="theme-num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
            <h3 class="theme-title">{th.title}</h3>
            <p class="theme-q">{th.question}</p>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .themes {
    background: var(--paper-2);
  }
  .themes-head {
    margin-bottom: var(--sp-5);
  }
  .themes-title {
    font-size: var(--fs-900);
  }
  .themes-grid {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 19rem), 1fr));
    gap: clamp(0.9rem, 1.6vw, 1.4rem);
  }
  .theme-card {
    position: relative;
    background: var(--fill);
    color: var(--ink);
    border-radius: var(--radius);
    padding: clamp(1.4rem, 2.4vw, 2.1rem);
    min-height: clamp(13rem, 24vw, 17rem);
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    overflow: hidden;
    box-shadow: var(--shadow);
    transition:
      transform 0.18s ease,
      box-shadow 0.18s ease;
  }
  .theme-card.on-dark {
    color: var(--white);
  }
  .theme-card::after {
    content: '';
    position: absolute;
    inset: auto 0 0 0;
    height: 6px;
    background: var(--shade);
    opacity: 0.5;
    transition:
      height 0.2s ease,
      opacity 0.2s ease;
  }
  .theme-card:hover,
  .theme-card:focus-within {
    transform: translateY(-6px);
    box-shadow: 0 22px 48px -18px rgba(11, 43, 51, 0.4);
  }
  .theme-card:hover::after,
  .theme-card:focus-within::after {
    height: 12px;
    opacity: 0.85;
  }
  .theme-num {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--fs-500);
    letter-spacing: 0.12em;
    opacity: 0.65;
  }
  .theme-title {
    font-family: var(--font-display);
    font-weight: 700;
    text-transform: uppercase;
    line-height: 1;
    font-size: clamp(1.5rem, 1rem + 1.8vw, 2.15rem);
    color: inherit;
    margin: auto 0 0;
  }
  .theme-q {
    font-size: var(--fs-400);
    line-height: 1.4;
    margin: 0;
    color: inherit;
    opacity: 0.82;
  }
  @media (prefers-reduced-motion: reduce) {
    .theme-card {
      transition: none;
    }
  }
</style>
