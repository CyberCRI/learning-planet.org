---
/**
 * Partner directory as a full-bleed "lineup wall": a festival-poster sponsor
 * wall — flat, dense, edge-to-edge, hairline grid, no card chrome. Same
 * visual family as ThemesLineup.astro (the key-themes wall the team adopted
 * in July 2026). Replaced PartnersDirectory.astro after the July 2026
 * design-lab round (variant C won the team review).
 */
import partners from '~/data/partners.json';
import { withBase } from '~/lib/paths';
import { EDITION, LINKS } from '~/site';
import { useTranslations, type Locale } from '~/i18n/utils';

interface Props {
  locale: Locale;
  intro: string;
}
const { locale, intro } = Astro.props;
const t = useTranslations(locale);

/** Normalise a name for search matching: lowercase, strip diacritics, collapse whitespace. */
function normName(value: string): string {
  return value
    .toLowerCase()
    .normalize('NFD')
    .replace(/\p{M}/gu, '')
    .replace(/\s+/g, ' ')
    .trim();
}

// Distinct letter buckets, digits first then A–Z. (Data order can't be used
// directly: quote-prefixed names like “Yes…and” sort before the digits.)
const letters = [...new Set(partners.map((p) => p.letter))].sort((a, b) => {
  const digitA = /^\d$/.test(a);
  const digitB = /^\d$/.test(b);
  if (digitA !== digitB) return digitA ? -1 : 1;
  return a.localeCompare(b);
});

// The five festival brights, cycled one-per-divider so consecutive letters
// never repeat a colour — the punctuation that makes the grayscale wall work.
const brights = ['--c-green', '--c-blue', '--c-lilac', '--c-coral', '--c-yellow'];

// Build one flat list of wall cells (dividers + partners) in letter-sorted
// order, and track a running index so only the first ~12 logos overall
// (not per-letter) load eagerly.
type WallCell =
  | { kind: 'divider'; letter: string; color: string }
  | { kind: 'partner'; partner: (typeof partners)[number]; eager: boolean };

let runningIndex = 0;
const cells: WallCell[] = letters.flatMap((letter, i) => {
  const divider: WallCell = { kind: 'divider', letter, color: brights[i % brights.length] };
  const partnerCells: WallCell[] = partners
    .filter((p) => p.letter === letter)
    .map((partner) => {
      const eager = runningIndex < 12;
      runningIndex += 1;
      return { kind: 'partner', partner, eager };
    });
  return [divider, ...partnerCells];
});

// The client script can't call t() — it splices the live count into this
// template at runtime instead (mirrors PartnersDirectory.astro's pattern).
const countTemplate = t('partners.count', { count: '{count}' });
const noResultsText = t('partners.noResults');
---

<header class="poster-header">
  <div class="container poster-inner">
    <div class="poster-figure">
      <p class="eyebrow">{EDITION.label}</p>
      <p class="poster-number h-bold" aria-hidden="true">{partners.length}</p>
      <h1 class="h-bold poster-heading">
        <span class="visually-hidden">{partners.length} </span>{t('partners.wallHeading')}
      </h1>
    </div>
    <p class="poster-intro">{intro}</p>
  </div>
  <hr class="rainbow-rule poster-rule" aria-hidden="true" />
</header>

{/* Shared wrapper = the strip's sticky containing block: it pins while the
    wall scrolls and releases before the CTA band, instead of shadowing the
    rest of the page. */}
<div class="wall-region">
<div class="utility-strip">
  <div class="container utility-inner">
    <div class="utility-toolbar" hidden>
      <label class="visually-hidden" for="partner-search">{t('partners.searchLabel')}</label>
      <input
        id="partner-search"
        type="search"
        placeholder={t('partners.searchPlaceholder')}
        autocomplete="off"
      />
      <p
        class="utility-status"
        aria-live="polite"
        data-count-template={countTemplate}
        data-no-results={noResultsText}
      ></p>
    </div>

    <nav class="jump-row" aria-label={t('partners.jumpLabel')}>
      {
        letters.map((letter) => (
          <a href={`#letter-${letter}`}>{letter}</a>
        ))
      }
    </nav>
  </div>
</div>

{/* Full-bleed on purpose: the sponsor-wall feel depends on the grid running
    edge to edge of the viewport, breaking out of .container's max-width.
    The gap is the hairline grid line — `gap: 1px` over a `--line`
    background lets each cell's own `--paper` fill read as a rule, with no
    per-cell borders needed. */}
<section class="wall" aria-label="All partners">
  {
    cells.map((cell) =>
      cell.kind === 'divider' ? (
        <div
          class="wall-cell divider-cell"
          id={`letter-${cell.letter}`}
          style={`--fill: var(${cell.color});`}
        >
          <span class="divider-letter h-bold">{cell.letter}</span>
        </div>
      ) : (
        <div
          class="wall-cell partner-cell"
          data-search={normName(cell.partner.name)}
          data-letter={cell.partner.letter}
        >
          {cell.partner.website ? (
            <a href={cell.partner.website} target="_blank" rel="noopener noreferrer">
              <span class="partner-logo">
                <img
                  src={withBase(cell.partner.logo)}
                  alt=""
                  width={cell.partner.width}
                  height={cell.partner.height}
                  loading={cell.eager ? 'eager' : 'lazy'}
                  decoding="async"
                />
              </span>
              <span class="partner-name">{cell.partner.name}</span>
            </a>
          ) : (
            <span class="partner-static">
              <span class="partner-logo">
                <img
                  src={withBase(cell.partner.logo)}
                  alt=""
                  width={cell.partner.width}
                  height={cell.partner.height}
                  loading={cell.eager ? 'eager' : 'lazy'}
                  decoding="async"
                />
              </span>
              <span class="partner-name">{cell.partner.name}</span>
            </span>
          )}
        </div>
      )
    )
  }
</section>
</div>

<section class="become-band">
  <hr class="rainbow-rule become-rule" aria-hidden="true" />
  <div class="container become-inner">
    <h2 class="h-bold become-title">{t('partners.becomeTitle')}</h2>
    <p class="become-text">{t('partners.becomeText')}</p>
    <div class="become-actions">
      <a class="btn become-btn-primary" href={LINKS.coDesignForm} target="_blank" rel="noopener">
        {t('partners.becomeCtaPrimary')}
      </a>
      <a class="btn become-btn-outline" href={`mailto:${LINKS.contactEmail}`}>
        {t('partners.becomeCtaSecondary')}
      </a>
    </div>
  </div>
</section>

<style>
  /* ---- poster header ---- */
  .poster-header {
    position: relative;
    background: var(--paper-2);
    padding-block: clamp(2.5rem, 6vw, 5rem) var(--sp-5);
  }
  .poster-rule {
    position: absolute;
    inset: auto 0 0 0;
  }
  .poster-inner {
    display: grid;
    gap: var(--sp-4);
  }
  .poster-figure {
    min-width: 0;
  }
  .poster-number {
    font-size: clamp(5rem, 16vw, 11rem);
    line-height: 0.85;
    margin: 0;
  }
  .poster-heading {
    font-size: var(--fs-800);
    margin: 0.2rem 0 0;
  }
  .poster-intro {
    font-size: var(--fs-500);
    color: var(--ink-soft);
    max-width: 60ch;
    margin: 0;
  }

  /* ---- sticky utility strip ---- */
  .utility-strip {
    position: sticky;
    /* The site header is sticky too (z-index 50) — stick just below it, not
       at 0, or the strip slides underneath. 84/72px track Header.astro's
       rendered heights (85/73px) with 1px of deliberate overlap. */
    top: 84px;
    z-index: 5;
    background: var(--paper);
    border-bottom: 1px solid var(--line);
  }
  .utility-inner {
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
    padding-block: var(--sp-2);
  }

  /* The scoped display rule would defeat the UA's [hidden] handling —
     keep the toolbar truly hidden until the filter script reveals it. */
  .utility-toolbar[hidden] {
    display: none;
  }
  .utility-toolbar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--sp-1) var(--sp-3);
  }
  .utility-toolbar input {
    font-family: var(--font-body);
    font-size: var(--fs-400);
    color: var(--ink);
    background: var(--white);
    border: 1px solid var(--line-strong);
    border-radius: var(--radius-sm);
    padding: 0.5rem 0.85rem;
    min-width: 220px;
  }
  .utility-toolbar input::placeholder {
    color: var(--ink-faint);
  }
  .utility-status {
    font-size: var(--fs-300);
    color: var(--ink-soft);
    margin: 0;
  }

  .jump-row {
    display: flex;
    gap: 0.35rem;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    padding-bottom: 2px; /* keeps focus rings from clipping on scroll */
  }
  .jump-row a {
    flex: none;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--fs-300);
    color: var(--ink-soft);
    background: var(--paper-2);
    border: 1px solid var(--line);
    border-radius: 999px;
    width: 1.8rem;
    height: 1.8rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    transition:
      background-color 0.15s ease,
      border-color 0.15s ease,
      color 0.15s ease;
  }
  .jump-row a:hover {
    border-color: var(--c-deep-teal);
    color: var(--ink);
  }

  @media (max-width: 560px) {
    .utility-strip {
      top: 72px;
    }
    .utility-toolbar input {
      width: 100%;
      min-width: 0;
    }
  }

  /* ---- the wall ---- */
  .wall {
    /* Already a direct child of the page flow (outside .container), so it is
       naturally edge-to-edge — no 100vw breakout needed (100vw would add a
       horizontal scrollbar wherever scrollbars take up layout space). */
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    /* The 1px gap over a --line fill is the hairline grid: no per-cell
       borders are drawn, the background bleeding through the gap IS the rule. */
    gap: 1px;
    background: var(--line);
  }
  .wall-cell {
    background: var(--paper);
  }
  .wall-cell[hidden] {
    display: none;
  }

  .divider-cell {
    background: var(--fill);
    color: var(--ink);
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 96px;
    /* Clears the sticky header + utility strip stack when a jump-link lands here. */
    scroll-margin-top: 12rem;
  }
  .divider-letter {
    font-size: var(--fs-800);
    line-height: 1;
  }

  .partner-cell {
    display: flex;
  }
  .partner-cell a,
  .partner-static {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
    padding: var(--sp-2);
    text-decoration: none;
    transition: background-color 0.15s ease;
  }
  .partner-cell a:hover,
  .partner-cell a:focus-within {
    background: var(--white);
  }
  .partner-logo {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 64px;
    width: 100%;
  }
  .partner-logo img {
    max-height: 100%;
    max-width: 100%;
    width: auto;
    object-fit: contain;
    filter: grayscale(1) opacity(0.72);
    transition:
      filter 0.2s ease,
      opacity 0.2s ease;
  }
  .partner-cell a:hover .partner-logo img,
  .partner-cell a:focus-visible .partner-logo img {
    filter: none;
    opacity: 1;
  }
  .partner-name {
    font-size: var(--fs-300);
    color: var(--ink-faint);
    text-align: center;
    line-height: 1.3;
  }
  .partner-cell a:hover .partner-name,
  .partner-cell a:focus-visible .partner-name {
    color: var(--ink);
  }
  .partner-cell a:focus-visible {
    background: var(--white);
    outline: var(--focus);
    outline-offset: -3px;
  }

  @media (prefers-reduced-motion: reduce) {
    .partner-logo img,
    .partner-cell a,
    .jump-row a {
      transition: none;
    }
  }

  /* ---- inverted become-a-partner CTA band ---- */
  .become-band {
    position: relative;
    background: var(--ink);
    color: var(--paper);
    text-align: center;
  }
  .become-rule {
    position: absolute;
    inset: 0 0 auto 0;
  }
  .become-inner {
    max-width: 46rem;
    padding-block: var(--sp-6);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--sp-2);
  }
  .become-title {
    font-size: var(--fs-900);
    color: var(--paper);
  }
  .become-text {
    font-size: var(--fs-500);
    color: color-mix(in srgb, var(--paper) 84%, transparent);
    max-width: 42ch;
    margin: 0 0 var(--sp-2);
  }
  .become-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--sp-2);
  }
  .become-btn-primary {
    background: var(--paper);
    color: var(--ink);
  }
  .become-btn-primary:hover {
    background: var(--white);
  }
  .become-btn-outline {
    background: transparent;
    color: var(--paper);
    border-color: rgba(255, 255, 255, 0.4);
  }
  .become-btn-outline:hover {
    border-color: var(--paper);
  }
</style>

<script>
  const toolbar = document.querySelector<HTMLDivElement>('.utility-toolbar');
  const searchInput = document.querySelector<HTMLInputElement>('#partner-search');
  const status = document.querySelector<HTMLParagraphElement>('.utility-status');
  const partnerCells = document.querySelectorAll<HTMLDivElement>('.partner-cell');
  const dividerCells = document.querySelectorAll<HTMLDivElement>('.divider-cell');

  if (toolbar && searchInput && status) {
    toolbar.hidden = false;

    const countTemplate = status.dataset.countTemplate ?? '';
    const noResultsText = status.dataset.noResults ?? '';

    function normalize(value: string): string {
      return value
        .toLowerCase()
        .normalize('NFD')
        .replace(/\p{M}/gu, '')
        .replace(/\s+/g, ' ')
        .trim();
    }

    function applyFilter() {
      const query = normalize(searchInput!.value);
      const isFiltered = query !== '';
      let visibleCount = 0;
      const visibleLetters = new Set<string>();

      partnerCells.forEach((cell) => {
        const search = cell.dataset.search ?? '';
        const matches = search.includes(query);
        cell.hidden = !matches;
        if (matches) {
          visibleCount += 1;
          visibleLetters.add(cell.dataset.letter ?? '');
        }
      });

      dividerCells.forEach((divider) => {
        const letter = divider.id.replace('letter-', '');
        divider.hidden = isFiltered && !visibleLetters.has(letter);
      });

      if (!isFiltered) {
        status!.textContent = '';
      } else if (visibleCount === 0) {
        status!.textContent = noResultsText;
      } else {
        status!.textContent = countTemplate.replace('{count}', String(visibleCount));
      }
    }

    searchInput.addEventListener('input', applyFilter);
  }
</script>
