---
import PageHero from './PageHero.astro';
import SharedGoals from './SharedGoals.astro';
import Timeline from './Timeline.astro';
import TeamGrid from './TeamGrid.astro';
import PoweredBy from './PoweredBy.astro';
import { intro, organisers } from '~/data/whoWeAre';
import { useTranslations, type Locale } from '~/i18n/utils';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);
---

<PageHero title={t('whoWeAre.title')} />

<section class="section container">
  <p class="wwa-intro prose">{intro}</p>

  <div class="organisers">
    <article class="organiser">
      <h2 class="org-name">{organisers.lpi.name}</h2>
      {organisers.lpi.paragraphs.map((p) => <p class="org-text" set:html={p} />)}
    </article>
    <article class="organiser">
      <h2 class="org-name">{organisers.unesco.name}</h2>
      {organisers.unesco.paragraphs.map((p) => <p class="org-text" set:html={p} />)}
    </article>
  </div>

  <div class="organisers-powered">
    <PoweredBy label={t('common.poweredBy')} variant="light" size="lg" />
  </div>
</section>

<section class="section container shared-goals-section">
  <h2 class="h-bold section-h">{t('whoWeAre.sharedGoals')}</h2>
  <SharedGoals />
</section>

<section class="section container">
  <h2 class="h-bold section-h">{t('whoWeAre.journey')}</h2>
  <Timeline />
</section>

<section class="section container team-section">
  <h2 class="h-bold section-h">{t('whoWeAre.team')}</h2>
  <TeamGrid locale={locale} />
</section>

<style>
  .wwa-intro {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: var(--fs-600);
    line-height: 1.4;
    color: var(--ink);
    max-width: 60ch;
    margin-bottom: var(--sp-5);
  }
  .organisers {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-4);
  }
  .org-name {
    font-family: var(--font-display);
    font-weight: 700;
    text-transform: uppercase;
    font-size: var(--fs-600);
    color: var(--c-deep-teal);
    margin-bottom: 0.6rem;
  }
  .org-text {
    color: var(--ink-soft);
    margin: 0;
  }
  .org-text + .org-text {
    margin-top: var(--sp-2);
  }
  .org-text :global(strong) {
    color: var(--ink);
  }
  .organisers-powered {
    margin-top: var(--sp-5);
    padding-top: var(--sp-4);
    border-top: 1px solid var(--line);
  }
  .section-h {
    font-size: var(--fs-800);
    margin-bottom: var(--sp-4);
  }
  .shared-goals-section,
  .team-section {
    background: var(--paper-2);
    border-radius: var(--radius);
  }

  @media (max-width: 720px) {
    .organisers {
      grid-template-columns: 1fr;
    }
  }
</style>
